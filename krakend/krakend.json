{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "Plataforma API Gateway",
  "port": 8080,
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "extra_config": {
    "security/cors": {
      "allow_origins": [
        "http://localhost:3000"
      ],
      "allow_methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "allow_headers": [
        "Origin",
        "Authorization",
        "Content-Type",
        "Accept"
      ],
      "expose_headers": [
        "Content-Length"
      ],
      "max_age": "12h"
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/usuarios/auth/login",
      "method": "POST",
      "input_headers": [
        "Content-Type"
      ],
      "backend": [
        {
          "url_pattern": "/api/usuarios/auth/login",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/usuarios/auth/register",
      "method": "POST",
      "input_headers": [
        "Content-Type"
      ],
      "backend": [
        {
          "url_pattern": "/api/usuarios/auth/register",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/mapeo/reportes",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/mapeo/reportes",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/mapeo/reportes",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "url_pattern": "/api/mapeo/reportes",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/mapeo/reportes/{id}/estado",
      "method": "PUT",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "url_pattern": "/api/mapeo/reportes/{id}/estado",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/usuarios/users/{id}",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "backend": [
        {
          "url_pattern": "/api/usuarios/users/{id}",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/usuarios/users/{id}",
      "method": "PUT",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "url_pattern": "/api/usuarios/users/{id}",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/mapeo/{id}",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/mapeo/{id}",
          "host": [
            "http://ms-bff:8080"
          ]
        }
      ]
    }
  ]
}
